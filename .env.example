NODE_ENV=development
PORT=3001

MONGODB_URI=mongodb://localhost:27017/econagro

# Origens permitidas pelo CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=troque_por_uma_chave_segura
JWT_EXPIRES_IN=7d

# Seed do primeiro admin (usado apenas com npm run seed:admin)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@econagro.com
SEED_ADMIN_PASSWORD=troque_por_senha_segura

# E-mail — obrigatório em produção; em desenvolvimento, necessário apenas para testar endpoints de e-mail
FRONTEND_URL=http://localhost:3000
MAIL_FROM=EconAgro <no-reply@econagro.com>
CONTACT_TO_EMAIL=caiqueazedo2005@gmail.com

# SMTP (ex: Gmail, Mailtrap, Resend SMTP relay, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
